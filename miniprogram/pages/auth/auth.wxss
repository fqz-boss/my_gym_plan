.au-root {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 64rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
}

.glass {
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border-radius: 28rpx;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.au-card {
  width: 100%;
  max-width: 600rpx;
  padding: 48rpx 40rpx 56rpx;
  text-align: center;
}

.au-logo {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 28rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.au-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a1a;
  letter-spacing: -0.5rpx;
}

.au-sub {
  margin-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #4a5568;
  text-align: left;
}

.au-agree {
  margin-top: 24rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: #a0aec0;
  text-align: left;
}

.au-btn {
  margin-top: 40rpx;
  border-radius: 20rpx !important;
  font-size: 30rpx !important;
  font-weight: 600;
}

.au-hint {
  margin-top: 28rpx;
  font-size: 24rpx;
  color: #7a8a9a;
  line-height: 1.4;
  text-align: left;
}
