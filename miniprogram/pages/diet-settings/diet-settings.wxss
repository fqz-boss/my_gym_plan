.ds-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 25rpx 29rpx calc(40rpx + env(safe-area-inset-bottom));
  background: #f7f8fa;
}
.ds-surface {
  background: #fff;
  border-radius: 29rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.04);
  padding: 29rpx 25rpx;
  box-sizing: border-box;
}
.ds-tip {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 25rpx;
  padding: 0 4rpx;
}
.ds-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f1f3;
  gap: 20rpx;
}
.ds-row:last-of-type {
  border-bottom: none;
}
.ds-lab {
  width: 180rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 500;
}
.ds-inp {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  padding: 12rpx 16rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
}
.ds-row--gender .ds-seg {
  flex: 1;
  display: flex;
  gap: 16rpx;
}
.ds-g {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 27rpx;
  color: #6b7280;
  background: #f0f1f3;
  border-radius: 14rpx;
}
.ds-g--on {
  background: #dcfce7;
  color: #166534;
  font-weight: 600;
}
.ds-row--picker {
  align-items: stretch;
  flex-direction: column;
  gap: 12rpx;
}
.ds-row--picker .ds-lab {
  width: 100%;
}
.ds-picker {
  width: 100%;
}
.ds-picker-in {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
}
.ds-picker-tx {
  font-size: 26rpx;
  color: #0f172a;
  line-height: 1.4;
  flex: 1;
  padding-right: 12rpx;
}
.ds-picker-chev {
  font-size: 20rpx;
  color: #9ca3af;
}
.ds-foot {
  margin-top: 40rpx;
  padding: 0 4rpx;
}
.ds-btn {
  background: #16a34a !important;
  border: none;
  color: #fff;
  font-weight: 600;
  border-radius: 18rpx;
}
