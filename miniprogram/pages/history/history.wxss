.page {
  padding: 0 32rpx 48rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.t1 {
  font-size: 64rpx;
  font-weight: 700;
  padding: 32rpx 0 8rpx;
}
.t2 {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 32rpx;
}
.empty {
  text-align: center;
  color: #8e8e93;
  font-size: 30rpx;
  padding: 80rpx 0;
  line-height: 1.6;
}

.h-item {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}
.h-h {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  gap: 16rpx;
}
.h-date {
  font-size: 30rpx;
  font-weight: 600;
  flex: 1;
}
.h-tag {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 32rpx;
  color: #fff;
}
.h-tag.push { background: #007aff; }
.h-tag.pull { background: #34c759; }
.h-tag.leg { background: #ff9500; }
.h-ar {
  font-size: 32rpx;
  color: #8e8e93;
  transition: transform 0.2s;
}
.h-ar.on {
  transform: rotate(90deg);
}
.h-d {
  padding: 0 32rpx 24rpx;
  display: none;
}
.h-d.on {
  display: block;
}
.h-ex { margin-bottom: 16rpx; }
.h-en {
  font-size: 26rpx;
  font-weight: 600;
  color: #3c3c43;
  margin-bottom: 4rpx;
}
.h-l {
  font-size: 24rpx;
  color: #8e8e93;
  line-height: 1.8;
}
.h-act {
  display: flex;
  border-top: 1rpx solid rgba(60, 60, 67, 0.1);
}
.h-act text {
  flex: 1;
  padding: 20rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
}
.h-edit { color: #007aff; }
.h-del { color: #ff3b30; }

.loading {
  text-align: center;
  color: #8e8e93;
  padding: 40rpx;
}
