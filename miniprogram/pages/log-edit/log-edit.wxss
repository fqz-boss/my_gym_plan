/* 与训练页同源的玻璃拟态、卡片、组数行、主按钮等 */
@import '../train/train.wxss';

.le-date {
  margin-bottom: 24rpx;
  padding: 24rpx 30rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-sizing: border-box;
}
.le-date-lb {
  font-size: 24rpx;
  color: #7a8a9a;
  font-weight: 600;
}
.le-date-inp {
  width: 100%;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(255, 255, 255, 0.55);
  border-radius: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.04);
}
/* 与日期块同级的单列选择，不做训练页「推/拉/腿」多按钮切换 */
.le-type-pick {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.55);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.04);
}
.le-type-tx {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.le-type-chev {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #7a8a9a;
  border-bottom: 3rpx solid #7a8a9a;
  transform: rotate(45deg);
  flex-shrink: 0;
  opacity: 0.6;
  margin-bottom: 4rpx;
}
.ex-name-inp {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1a1a;
  background: transparent;
  border: none;
  padding: 0;
  height: 44rpx;
  line-height: 44rpx;
}
.ex-name-inp::placeholder {
  color: rgba(122, 138, 154, 0.65);
  font-weight: 600;
}
.le-loading {
  text-align: center;
  color: #7a8a9a;
  font-size: 30rpx;
  font-weight: 600;
  padding: 120rpx 32rpx;
}
.fin {
  margin-top: 8rpx;
}
