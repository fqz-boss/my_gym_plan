.page {
  padding: 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  min-height: 100vh;
  background: #f2f2f7;
}
.l {
  font-size: 26rpx;
  color: #8e8e93;
  margin: 20rpx 0 8rpx;
}
.inp {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  width: 100%;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
}
.picker {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
}
.ex-block {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.1);
}
.exn {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 8rpx;
}
.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
  flex-wrap: wrap;
}
.sl {
  font-size: 24rpx;
  color: #8e8e93;
  width: 80rpx;
  flex-shrink: 0;
}
.si {
  width: 140rpx;
  text-align: center;
  background: #f2f2f7;
  border-radius: 12rpx;
  padding: 12rpx;
  font-size: 28rpx;
}
.ch {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #3c3c43;
  margin-left: auto;
}
.ch-t {
  font-size: 28rpx;
  color: #34c759;
  margin-right: 4rpx;
}
.save {
  margin-top: 40rpx;
  background: #007aff;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;
  padding: 28rpx;
  border: none;
}
.save::after {
  border: none;
}
