.page {
  padding: 0 32rpx 48rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-title {
  font-size: 64rpx;
  font-weight: 700;
  padding: 32rpx 0 16rpx;
  letter-spacing: -1rpx;
}

.page-sub {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 32rpx;
}

.day-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.day-btn {
  flex: 1;
  min-width: 140rpx;
  padding: 20rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  background: #fff;
  color: #3c3c43;
}

.day-btn.on-push {
  background: #007aff;
  color: #fff;
}
.day-btn.on-pull {
  background: #34c759;
  color: #fff;
}
.day-btn.on-leg {
  background: #ff9500;
  color: #fff;
}
.day-btn.on-rest {
  background: #c7c7cc;
  color: #fff;
}

.tip-banner {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.tip-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 6rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #3c3c43;
  line-height: 1.5;
  flex: 1;
}

.ex-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.ex-head {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  gap: 20rpx;
}

.ex-badge {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.ex-name {
  font-size: 30rpx;
  font-weight: 600;
  flex: 1;
}

.ex-meta {
  font-size: 24rpx;
  color: #8e8e93;
}

.tip-link {
  font-size: 24rpx;
  color: #007aff;
  padding: 0 32rpx 8rpx;
}

.ex-tips {
  padding: 0 32rpx 24rpx;
  font-size: 26rpx;
  color: #8e8e93;
  line-height: 1.6;
}

.set-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.1);
  margin: 0 32rpx;
}
.set-row:last-of-type {
  border-bottom: none;
}

.set-label {
  width: 72rpx;
  font-size: 26rpx;
  color: #8e8e93;
  flex-shrink: 0;
}

.set-input {
  width: 120rpx;
  text-align: center;
  font-size: 30rpx;
  padding: 8rpx;
  border-bottom: 2rpx solid rgba(60, 60, 67, 0.15);
}

.set-unit {
  font-size: 24rpx;
  color: #8e8e93;
  width: 32rpx;
  flex-shrink: 0;
}

.set-check {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d1d6;
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
}

.set-check.on {
  border-color: #34c759;
  background: #34c759;
}

.set-check .tick {
  display: none;
  color: #fff;
  font-weight: 700;
}
.set-check.on .tick {
  display: block;
}

.add-set {
  width: 100%;
  padding: 20rpx;
  font-size: 26rpx;
  color: #007aff;
  font-weight: 500;
  text-align: center;
  background: transparent;
  border: none;
}

.add-set::after {
  border: none;
}

.rest-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.rest-emo {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}
.rest-h {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.rest-p {
  font-size: 28rpx;
  color: #8e8e93;
  line-height: 1.6;
}

.btn {
  display: block;
  width: 100%;
  padding: 32rpx;
  border-radius: 28rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-top: 32rpx;
  color: #fff;
  border: none;
}
.btn::after {
  border: none;
}
.btn.muted {
  background: #e5e5ea;
  color: #000;
  margin-top: 24rpx;
}
.btn.push {
  background: #007aff;
}
.btn.pull {
  background: #34c759;
}
.btn.leg {
  background: #ff9500;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.dlg {
  width: 100%;
  max-width: 1000rpx;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
.dlg-t {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}
.dlg-d {
  font-size: 28rpx;
  color: #8e8e93;
  text-align: center;
  margin-bottom: 32rpx;
}
.dlg-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.dlg-btns button {
  flex: 1;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx;
  border: none;
}
.dlg-btns button::after {
  border: none;
}
.dlg-cancel {
  background: #f2f2f7;
  color: #000;
}
.dlg-ok {
  background: #007aff;
  color: #fff;
}

.ex-pad {
  padding: 0 32rpx 24rpx;
}
