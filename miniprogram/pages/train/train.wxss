/* Smart Fitness 玻璃风 — 与 web/index 对齐 */
.train-root {
  padding: 0 32rpx 200rpx;
  padding-left: max(32rpx, env(safe-area-inset-left));
  padding-right: max(32rpx, env(safe-area-inset-right));
  padding-top: 12rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.glass {
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.75);
  border-radius: 22rpx;
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}
.glass-d {
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 24rpx 24rpx 0 0;
}

.dash-hd {
  margin-bottom: 20rpx;
  padding-top: 8rpx;
}
.dash-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 20rpx;
}
.dash-av {
  width: 104rpx;
  height: 104rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #7fb3ff, #4a90e2);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.dash-av-inner {
  width: 100%;
  height: 100%;
  position: relative;
  color: rgba(255, 255, 255, 0.96);
}
.dash-dumb {
  position: absolute;
  background: currentColor;
  border-radius: 6rpx;
}
.dash-dumb.r1 {
  left: 18%;
  top: 28%;
  width: 20%;
  height: 32%;
  transform: rotate(-32deg);
  transform-origin: center;
}
.dash-dumb.r2 {
  right: 18%;
  top: 28%;
  width: 20%;
  height: 32%;
  transform: rotate(-32deg);
}
.dash-dumb.bar {
  left: 32%;
  top: 40%;
  width: 36%;
  height: 12%;
  border-radius: 10rpx;
  transform: rotate(-32deg);
  transform-origin: center;
}

.dash-txt {
  flex: 1;
  min-width: 0;
}
.dash-hello {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a1a;
  line-height: 1.2;
  letter-spacing: -0.6rpx;
}
.dash-sub {
  font-size: 24rpx;
  color: #7a8a9a;
  font-weight: 500;
  margin-top: 6rpx;
}

.stats-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.stat-gl {
  flex: 1;
  text-align: center;
  padding: 18rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05), inset 0 1rpx 0 rgba(255, 255, 255, 0.75);
}
.stat-n {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #4a90e2;
  font-variant-numeric: tabular-nums;
  line-height: 1.2;
}
.stat-lb {
  display: block;
  font-size: 20rpx;
  color: #7a8a9a;
  font-weight: 600;
  margin-top: 6rpx;
  text-transform: uppercase;
  letter-spacing: 0.8rpx;
}

.pill-row {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
  flex-wrap: wrap;
}
.pill {
  font-size: 20rpx;
  font-weight: 800;
  color: #7a8a9a;
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.45);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  letter-spacing: 1.2rpx;
}

.page-t {
  font-size: 50rpx;
  font-weight: 800;
  color: #1a1a1a;
  padding: 16rpx 0 20rpx;
  letter-spacing: -1rpx;
}

.day-sel {
  display: flex;
  gap: 10rpx;
  margin-bottom: 24rpx;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.35);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.04);
}
.d-btn {
  flex: 1;
  padding: 20rpx 4rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a5568;
  background: transparent;
}
.d-btn.ac-push,
.d-btn.ac-pull,
.d-btn.ac-leg,
.d-btn.ac-rest {
  color: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.12);
}
.d-btn.ac-push {
  background: linear-gradient(145deg, #4a90e2, #3a7bc8);
}
.d-btn.ac-pull {
  background: linear-gradient(145deg, #7fb3ff, #5a9ae8);
}
.d-btn.ac-leg {
  background: linear-gradient(145deg, #5ae0c3, #3bc4a8);
}
.d-btn.ac-rest {
  background: linear-gradient(145deg, #9ca8b8, #7a8798);
}

.tip-banner {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 20rpx;
}
.tip-m {
  margin-top: 6rpx;
}
.tip-d {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-top: 4rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}
.tip--push .tip-d {
  background: #4a90e2;
}
.tip--pull .tip-d {
  background: #7fb3ff;
}
.tip--leg .tip-d {
  background: #5ae0c3;
}
.tip--rest .tip-d {
  background: #9ca8b8;
}
.tip-tx {
  flex: 1;
  font-size: 24rpx;
  color: #4a5568;
  line-height: 1.5;
  font-weight: 500;
}

.ex-card {
  margin-bottom: 20rpx;
  overflow: hidden;
}
.ex-head {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  gap: 20rpx;
}
.ex-bd {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.ex--push .ex-bd {
  background: #4a90e2;
  box-shadow: 0 0 0 4rpx rgba(74, 144, 226, 0.25);
}
.ex--pull .ex-bd {
  background: #7fb3ff;
  box-shadow: 0 0 0 4rpx rgba(127, 179, 255, 0.3);
}
.ex--leg .ex-bd {
  background: #5ae0c3;
  box-shadow: 0 0 0 4rpx rgba(94, 224, 195, 0.28);
}
.ex-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1a1a;
}
.ex-meta {
  font-size: 22rpx;
  color: #7a8a9a;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(74, 144, 226, 0.1);
  white-space: nowrap;
}
.ex--pull .ex-meta {
  background: rgba(127, 179, 255, 0.15);
}
.ex--leg .ex-meta {
  background: rgba(94, 224, 195, 0.12);
}
.ex-more {
  font-size: 22rpx;
  color: #4a90e2;
  font-weight: 600;
  padding: 0 30rpx 12rpx;
}
.ex-tip {
  padding: 0 30rpx 20rpx;
  font-size: 24rpx;
  color: #7a8a9a;
  line-height: 1.65;
  font-weight: 500;
}
.ex-sets {
  padding: 0 30rpx 20rpx;
}
.s-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}
.s-lb {
  width: 72rpx;
  font-size: 24rpx;
  color: #7a8a9a;
  font-weight: 800;
  flex-shrink: 0;
}
.s-inp {
  width: 100rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  padding: 10rpx 6rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.65);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.04);
  font-variant-numeric: tabular-nums;
}
.s-ut {
  font-size: 20rpx;
  color: #7a8a9a;
  width: 32rpx;
  font-weight: 700;
}
.s-ck {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(122, 138, 154, 0.35);
  background: rgba(255, 255, 255, 0.5);
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.s-ck.ok {
  border-color: #5ae0c3;
  background: linear-gradient(145deg, #5ae0c3, #3bc9a8);
  box-shadow: 0 4rpx 12rpx rgba(94, 224, 195, 0.45);
}

.add-s {
  display: block;
  width: 100%;
  padding: 20rpx;
  font-size: 24rpx;
  color: #4a90e2;
  font-weight: 800;
  text-align: center;
  background: rgba(74, 144, 226, 0.07);
  border: none;
  border-radius: 0 0 20rpx 20rpx;
  margin: 0 -1rpx -1rpx;
}
.add-s::after {
  border: none;
}

.fin-sec,
.fin {
  display: block;
  width: 100%;
  padding: 32rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
  border: none;
  margin-top: 16rpx;
}
.fin-sec::after,
.fin::after {
  border: none;
}
.fin-sec {
  margin-top: 24rpx;
  color: #1a1a1a;
  background: rgba(255, 255, 255, 0.65);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.fin {
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
}
.fin.push {
  background: linear-gradient(145deg, #4a90e2, #3a7bc8);
}
.fin.pull {
  background: linear-gradient(145deg, #7fb3ff, #5a9ae8);
}
.fin.leg {
  background: linear-gradient(145deg, #5ae0c3, #3bc4a8);
}

.rest {
  padding: 64rpx 40rpx;
  text-align: center;
}
.rest-emo {
  font-size: 96rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 2rpx 6rpx rgba(0, 0, 0, 0.1));
}
.rest-h {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}
.rest-p {
  font-size: 26rpx;
  color: #7a8a9a;
  line-height: 1.65;
  font-weight: 500;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(26, 26, 26, 0.35);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.dia {
  width: 100%;
  max-width: 1000rpx;
  padding: 36rpx 32rpx calc(36rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, 0.1);
  animation: up 0.28s cubic-bezier(0.32, 0.72, 0, 1);
}
@keyframes up {
  from {
    transform: translateY(100%);
    opacity: 0.9;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
.dia-tt {
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  letter-spacing: -0.5rpx;
}
.dia-s {
  font-size: 26rpx;
  color: #7a8a9a;
  text-align: center;
  font-weight: 500;
  margin-bottom: 16rpx;
}
.dia-bn {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}
.dia-b {
  flex: 1;
  border-radius: 20rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  border: none;
}
.dia-b::after {
  border: none;
}
.dia-b.can {
  color: #1a1a1a;
  background: rgba(238, 243, 248, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}
.dia-b.ok {
  color: #fff;
  background: linear-gradient(145deg, #4a90e2, #3a7bc8);
  box-shadow: 0 4rpx 14rpx rgba(74, 144, 226, 0.35);
}
