<view class="train-root">
  <view class="dash-hd" wx:if="{{!isRest}}">
    <view class="dash-row">
      <button wx:if="{{canChangeAvatar}}" class="dash-av dash-av--btn" open-type="chooseAvatar" bindchooseavatar="onTrainChooseAvatar" hover-class="dash-av--pressed" aria-label="更换头像">
        <image wx:if="{{userAvatarUrl}}" class="dash-av-img" src="{{userAvatarUrl}}" mode="aspectFill" />
        <view wx:else class="dash-av-inner">
          <view class="dash-dumb r1" />
          <view class="dash-dumb r2" />
          <view class="dash-dumb bar" />
        </view>
      </button>
      <view wx:else class="dash-av dash-av--guest" bindtap="onTrainAvatarTapWhenGuest" hover-class="dash-av--pressed" aria-hidden="true">
        <image wx:if="{{userAvatarUrl}}" class="dash-av-img" src="{{userAvatarUrl}}" mode="aspectFill" />
        <view wx:else class="dash-av-inner">
          <view class="dash-dumb r1" />
          <view class="dash-dumb r2" />
          <view class="dash-dumb bar" />
        </view>
      </view>
      <view class="dash-txt">
        <view class="dash-hello">{{dashHello}}</view>
        <view class="dash-sub">{{trainDate}}</view>
      </view>
    </view>
    <view class="stats-row">
      <view class="stat-gl">
        <text class="stat-n">{{statWeek}}</text>
        <text class="stat-lb">本周</text>
      </view>
      <view class="stat-gl">
        <text class="stat-n">{{statToday}}</text>
        <text class="stat-lb">今日</text>
      </view>
      <view class="stat-gl stat-tap" hover-class="stat-tap--on" catchtap="onOpenCal">
        <text class="stat-n">{{statTotal}}</text>
        <text class="stat-lb">总计</text>
      </view>
    </view>
  </view>

  <view class="dash-hd rest-dash" wx:if="{{isRest}}">
    <view class="dash-row">
      <button wx:if="{{canChangeAvatar}}" class="dash-av dash-av--btn" open-type="chooseAvatar" bindchooseavatar="onTrainChooseAvatar" hover-class="dash-av--pressed" aria-label="更换头像">
        <image wx:if="{{userAvatarUrl}}" class="dash-av-img" src="{{userAvatarUrl}}" mode="aspectFill" />
        <view wx:else class="dash-av-inner">
          <view class="dash-dumb r1" />
          <view class="dash-dumb r2" />
          <view class="dash-dumb bar" />
        </view>
      </button>
      <view wx:else class="dash-av dash-av--guest" bindtap="onTrainAvatarTapWhenGuest" hover-class="dash-av--pressed" aria-hidden="true">
        <image wx:if="{{userAvatarUrl}}" class="dash-av-img" src="{{userAvatarUrl}}" mode="aspectFill" />
        <view wx:else class="dash-av-inner">
          <view class="dash-dumb r1" />
          <view class="dash-dumb r2" />
          <view class="dash-dumb bar" />
        </view>
      </view>
      <view class="dash-txt">
        <view class="dash-hello">{{dashHello}}</view>
        <view class="dash-sub">{{trainDate}}</view>
      </view>
    </view>
    <view class="stats-row">
      <view class="stat-gl">
        <text class="stat-n">{{statWeek}}</text>
        <text class="stat-lb">本周</text>
      </view>
      <view class="stat-gl">
        <text class="stat-n">休息</text>
        <text class="stat-lb">今日</text>
      </view>
      <view class="stat-gl stat-tap" hover-class="stat-tap--on" catchtap="onOpenCal">
        <text class="stat-n">{{statTotal}}</text>
        <text class="stat-lb">总计</text>
      </view>
    </view>
  </view>

  <view class="page-t">{{trainTitle}}</view>

  <view class="day-sel">
    <view class="d-btn {{currentDay==='push' ? 'ac-push' : ''}}" data-day="push" bindtap="onSwitchDay">推日</view>
    <view class="d-btn {{currentDay==='pull' ? 'ac-pull' : ''}}" data-day="pull" bindtap="onSwitchDay">拉日</view>
    <view class="d-btn {{currentDay==='leg' ? 'ac-leg' : ''}}" data-day="leg" bindtap="onSwitchDay">腿日</view>
    <view class="d-btn {{currentDay==='rest' ? 'ac-rest' : ''}}" data-day="rest" bindtap="onSwitchDay">休息</view>
  </view>

  <view class="train-plan-link glass" hover-class="train-plan-link--on" bindtap="onOpenPlan">
    <text class="train-plan-link-tx">查看完整计划</text>
    <text class="train-plan-link-ico">›</text>
  </view>

  <block wx:if="{{isRest}}">
    <view class="rest glass">
      <view class="rest-emo">🧘</view>
      <view class="rest-h">今日休息</view>
      <view class="rest-p">可做低强度有氧（散步、瑜伽），促进血液循环与肌肉恢复。充足睡眠，合理饮食，为下一轮训练蓄力。</view>
    </view>
  </block>

  <block wx:else>
    <view class="tip-banner glass tip--{{cardCls}}">
      <view class="tip-d" />
      <text class="tip-tx">训练前请完成10-15分钟热身：有氧5分钟 + 动态拉伸 + 专项热身组</text>
    </view>

    <view class="ex-card glass ex--{{cardCls}}" wx:for="{{exerciseRows}}" wx:for-item="ex" wx:for-index="ei" wx:key="ei">
      <view class="ex-head">
        <view class="ex-ico ex-ico--{{cardCls}}" data-ei="{{ei}}" catchtap="onToggleTips">
          <view class="ex-ico-inner">
            <image class="ex-ico-img" src="{{ex.icon}}" mode="aspectFit" />
          </view>
        </view>
        <input
          class="ex-name ex-name-inp"
          value="{{ex.name}}"
          placeholder="动作名称"
          data-ei="{{ei}}"
          bindinput="onExerciseNameInput"
          catchtap="noop"
        />
        <view class="ex-meta" data-ei="{{ei}}" catchtap="onToggleTips">{{ex.repsMeta}}</view>
      </view>
      <view class="ex-more" data-ei="{{ei}}" catchtap="onToggleTips">{{ex.tipsOpen ? '收起要点' : '查看要点'}}</view>
      <view class="ex-tip" wx:if="{{ex.tipsOpen}}">{{ex.tips}}</view>
      <view class="ex-sets">
        <view class="s-row" wx:for="{{ex.sets}}" wx:for-item="row" wx:for-index="si" wx:key="si">
          <text class="s-lb">第{{si + 1}}组</text>
          <input
            class="s-inp"
            type="digit"
            placeholder="0"
            value="{{row.weight}}"
            data-ei="{{ei}}"
            data-si="{{si}}"
            data-f="weight"
            bindinput="onSetInput"
            catchtap="noop"
          />
          <text class="s-ut">kg</text>
          <input
            class="s-inp"
            type="number"
            placeholder="0"
            value="{{row.reps}}"
            data-ei="{{ei}}"
            data-si="{{si}}"
            data-f="reps"
            bindinput="onSetInput"
            catchtap="noop"
          />
          <text class="s-ut">次</text>
          <view
            class="s-ck {{row.done ? 'ok' : ''}}"
            data-ei="{{ei}}"
            data-si="{{si}}"
            catchtap="onToggleDone"
          >
            <text class="tick" wx:if="{{row.done}}">✓</text>
          </view>
        </view>
        <button class="add-s" data-ei="{{ei}}" bindtap="onAddSet">+ 添加一组</button>
      </view>
    </view>

    <view class="tip-banner glass tip--{{cardCls}} tip-m">
      <view class="tip-d" />
      <text class="tip-tx">训练后请完成5-10分钟拉伸：针对今日训练肌群，每部位30-60秒×2组</text>
    </view>
    <button class="fin-sec" bindtap="onSaveDraft">保存草稿</button>
    <button class="fin {{btnCls}}" bindtap="onOpenFinish">完成今日训练</button>
  </block>
</view>

<view class="cal-mask" wx:if="{{showCal}}" catchtouchmove="noop" bindtap="closeCal">
  <view class="cal-sheet" catchtap="noop">
    <view class="cal-hd">
      <view class="cal-nav" hover-class="cal-nav--down" data-role="nav" catchtap="onPrevCalMonth">
        <view class="cal-chev cal-chev--l" />
      </view>
      <picker
        class="cal-picker"
        mode="date"
        fields="month"
        value="{{calPickerValue}}"
        start="2016-01-01"
        end="{{calPickerEnd}}"
        bindchange="onCalMonthPick"
      >
        <view class="cal-mtitle" hover-class="cal-mtitle--down">
          <text class="cal-mtext">{{calTitle}}</text>
          <view class="cal-tt-chev" />
        </view>
      </picker>
      <view
        class="cal-nav {{calNextDisabled ? 'cal-nav--off' : ''}}"
        hover-class="cal-nav--down"
        data-role="nav"
        catchtap="onNextCalMonth"
      >
        <view class="cal-chev" />
      </view>
    </view>

    <view class="cal-wkhead" aria-label="周">
      <text
        class="cal-wh {{wi === 6 ? 'cal-wh--sun' : ''}}"
        wx:for="{{calWkNames}}"
        wx:for-index="wi"
        wx:key="wi"
      >{{item}}</text>
    </view>

    <view class="cal-wk" wx:for="{{calWeeks}}" wx:for-item="wk" wx:for-index="wix" wx:key="wix">
      <view
        class="{{cell.dClass}}"
        wx:for="{{wk}}"
        wx:for-item="cell"
        wx:for-index="cix"
        wx:key="key"
        data-key="{{!cell.empty ? cell.key : ''}}"
        data-empty="{{cell.empty ? 1 : 0}}"
        catchtap="onCalSelectDay"
      >
        <view class="cal-d-bounds{{cell.empty ? ' cal-d-bounds--empty' : ''}}">
          <view wx:if="{{!cell.empty}}" class="cal-d-body">
            <view
              class="cal-dn {{cell.key === calSelectedKey ? 'cal-dn--sel' : (cell.isSunday ? 'cal-dn--sun' : 'cal-dn--muted')}}"
            >{{cell.day}}</view>
            <view class="cal-tags" wx:if="{{cell.logs && cell.logs.length}}">
              <view
                class="cal-tag cal-tag--{{t.cls}}"
                wx:for="{{cell.logs}}"
                wx:for-item="t"
                wx:for-index="li"
                wx:key="type"
              >
                <text class="cal-tag-tx">{{t.short}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="cal-legend" aria-label="图例">
      <view class="cal-legal">
        <view class="cal-tag cal-tag--pull">
          <text class="cal-tag-tx">拉</text>
        </view>
        <text class="cal-legtxt">拉练日</text>
      </view>
      <view class="cal-legal">
        <view class="cal-tag cal-tag--push">
          <text class="cal-tag-tx">推</text>
        </view>
        <text class="cal-legtxt">推练日</text>
      </view>
      <view class="cal-legal">
        <view class="cal-tag cal-tag--leg">
          <text class="cal-tag-tx">腿</text>
        </view>
        <text class="cal-legtxt">腿部训练日</text>
      </view>
    </view>

    <view class="cal-btrow">
      <button class="cal-btn-close" bindtap="closeCal">关闭</button>
    </view>
  </view>
</view>

<view class="mask" wx:if="{{showFinish}}" catchtouchmove="noop" bindtap="onCloseFinish">
  <view class="dia glass-d" catchtap="noop">
    <view class="dia-tt">完成今日训练？</view>
    <view class="dia-s">训练数据将保存到历史记录</view>
    <view class="dia-bn">
      <button class="dia-b can" bindtap="onCloseFinish">取消</button>
      <button class="dia-b ok" bindtap="onConfirmFinish">确认完成</button>
    </view>
  </view>
</view>
<auth-overlay
  visible="{{authOverlayVisible}}"
  hint="{{authOverlayHint}}"
  bind:close="onAuthOverlayClose"
  bind:success="onAuthOverlaySuccess"
/>
