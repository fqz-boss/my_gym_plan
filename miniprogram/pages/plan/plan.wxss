.page {
  padding: 0 32rpx 48rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}
.t1 {
  font-size: 64rpx;
  font-weight: 700;
  padding: 32rpx 0 8rpx;
}
.t2 {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 24rpx;
}

.edit-sec {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.edit-h {
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.1);
}
.day-h {
  font-size: 28rpx;
  font-weight: 600;
  color: #3c3c43;
  padding: 20rpx 32rpx;
  background: #f2f2f7;
}
.ex-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.08);
}
.ex-n {
  flex: 1;
  font-size: 28rpx;
  color: #000;
}
.ex-m {
  font-size: 24rpx;
  color: #8e8e93;
  flex-shrink: 0;
}
.ex-btns {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}
.ex-btns text {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  color: #007aff;
  font-weight: 500;
}
.ex-btns .del {
  color: #ff3b30;
}
.add-bt {
  width: 100%;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #007aff;
  font-weight: 500;
  background: #fff;
  border: none;
}
.add-bt::after {
  border: none;
}

.ps {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}
.ps-h {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.ps-ar {
  font-size: 28rpx;
  color: #8e8e93;
  transition: transform 0.2s;
}
.ps-ar.on {
  transform: rotate(90deg);
}
.ps-b {
  display: none;
  padding: 0 32rpx 24rpx;
  font-size: 26rpx;
  color: #3c3c43;
  line-height: 1.8;
}
.ps-b.on {
  display: block;
}
.rich {
  width: 100%;
  overflow: hidden;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.dlg {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
}
.dlg-t {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}
.dl {
  font-size: 26rpx;
  color: #8e8e93;
  margin: 12rpx 0 6rpx;
}
.di {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}
.dlg-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.dlg-btns button {
  flex: 1;
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}
.dlg-btns button::after {
  border: none;
}
.bc {
  background: #f2f2f7;
  color: #000;
}
.bo {
  background: #007aff;
  color: #fff;
}
