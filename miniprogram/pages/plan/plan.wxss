.pl-root {
  padding: 0 32rpx 48rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  padding-top: 12rpx;
}

.glass {
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border-radius: 24rpx;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}
.glass-d {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 24rpx 24rpx 0 0;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
}

.t1 {
  font-size: 50rpx;
  font-weight: 800;
  color: #1a1a1a;
  padding: 20rpx 0 6rpx;
  letter-spacing: -1rpx;
  padding-top: 16rpx;
  padding-top: max(12rpx, env(safe-area-inset-top));
}
@import '../../styles/exercise-icon.wxss';

.t2 {
  font-size: 26rpx;
  color: #7a8a9a;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.edit-sec {
  margin-bottom: 24rpx;
  overflow: hidden;
}
.edit-sec-t {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}
.edit-sec-t.is-collapsed {
  border-bottom: none;
}
.edit-txt {
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1a1a;
  flex: 1;
  min-width: 0;
}
.edit-sec-ar {
  font-size: 28rpx;
  color: #7a8a9a;
  flex-shrink: 0;
  margin-left: 12rpx;
  transition: transform 0.25s ease;
  line-height: 1;
  font-weight: 600;
}
.edit-sec-ar.on {
  transform: rotate(90deg);
}
.edit-hint {
  font-size: 22rpx;
  color: #7a8a9a;
  padding: 6rpx 32rpx 20rpx;
  line-height: 1.45;
  font-weight: 500;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}
.day-h {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  font-weight: 800;
  color: #4a5568;
  padding: 20rpx 32rpx;
  background: rgba(255, 255, 255, 0.4);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}
.day-lb {
  flex: 1;
  min-width: 0;
}
.day-ar {
  font-size: 28rpx;
  color: #7a8a9a;
  flex-shrink: 0;
  margin-left: 12rpx;
  transition: transform 0.25s ease;
  line-height: 1;
  font-weight: 600;
}
.day-ar.on {
  transform: rotate(90deg);
}
.plan-list {
  min-height: 8rpx;
}
.ex-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}
.drag-h {
  flex-shrink: 0;
  width: 56rpx;
  height: 60rpx;
  border-radius: 14rpx;
  background: rgba(122, 138, 154, 0.15);
  color: #7a8a9a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 900;
}
.ex-n {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.ex-m {
  font-size: 20rpx;
  color: #7a8a9a;
  font-weight: 600;
  flex-shrink: 0;
}
.ex-btns {
  display: flex;
  gap: 4rpx;
  flex-shrink: 0;
}
.ex-btns text {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  color: #4a90e2;
  font-weight: 800;
  background: rgba(74, 144, 226, 0.1);
  border-radius: 10rpx;
}
.ex-btns .del {
  color: #e85d5d;
  background: rgba(232, 93, 93, 0.1);
}
.add-bt {
  width: 100%;
  padding: 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: #4a90e2;
  font-weight: 800;
  background: rgba(255, 255, 255, 0.4);
  border: none;
}
.add-bt::after {
  border: none;
}

.ps {
  margin-bottom: 20rpx;
  overflow: hidden;
}
.ps-h {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1a1a;
}
.ps-ar {
  font-size: 26rpx;
  color: #7a8a9a;
  transition: transform 0.25s ease;
}
.ps-ar.on {
  transform: rotate(90deg);
}
.ps-b {
  display: none;
  padding: 0 32rpx 24rpx;
  font-size: 24rpx;
  color: #4a5568;
  line-height: 1.7;
  font-weight: 500;
}
.ps-b.on {
  display: block;
}
.rich {
  width: 100%;
}

.p-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(26, 26, 26, 0.32);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.dlg {
  width: 100%;
  max-width: 1000rpx;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  animation: up2 0.3s ease;
}
@keyframes up2 {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}
.dlg-t {
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 20rpx;
  color: #1a1a1a;
}
.dl {
  font-size: 24rpx;
  color: #7a8a9a;
  font-weight: 600;
  margin: 8rpx 0 4rpx;
}
/* input 无明确 line-height/高度时，部分机型会裁切字顶，需固定行高与 min-height */
.di {
  width: 100%;
  min-height: 88rpx;
  line-height: 44rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.75);
  font-size: 30rpx;
  margin-bottom: 14rpx;
  font-weight: 500;
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}
.di--tips {
  min-height: 120rpx;
  line-height: 1.55;
  padding: 18rpx 24rpx;
  width: 100%;
}
.dlg-bn {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}
.d-bc,
.d-ok {
  flex: 1;
  border-radius: 20rpx;
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: 800;
  border: none;
}
.d-bc::after,
.d-ok::after {
  border: none;
}
.d-bc {
  background: rgba(238, 243, 248, 0.9);
  color: #1a1a1a;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}
.d-ok {
  color: #fff;
  background: linear-gradient(145deg, #4a90e2, #3a7bc8);
  box-shadow: 0 4rpx 14rpx rgba(74, 144, 226, 0.35);
}
