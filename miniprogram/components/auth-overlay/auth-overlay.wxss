.auth-ol {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-ol-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(26, 26, 26, 0.45);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}

.auth-ol-inner {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 620rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.glass {
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
  border-radius: 28rpx;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.auth-ol-card {
  padding: 44rpx 36rpx 36rpx;
  text-align: center;
}

.auth-ol-logo {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.auth-ol-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.auth-ol-sub {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #4a5568;
  text-align: left;
}

.auth-ol-btn {
  margin-top: 32rpx;
  border-radius: 20rpx !important;
  font-size: 28rpx !important;
  font-weight: 600;
}

.auth-ol-msg {
  margin-top: 20rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #7a8a9a;
  text-align: left;
}

.auth-ol-close {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #718096;
  padding: 8rpx;
}
